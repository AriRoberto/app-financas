# Open Finance real (Pluggy)
# Desative o mock para usar conexão real via consentimento
OPEN_FINANCE_MOCK=false

# Base da API Pluggy (modo real)
AISP_BASE_URL=https://api.pluggy.ai

# Credenciais do My Pluggy
AISP_CLIENT_ID=SEU_CLIENT_ID_PLUGGY
AISP_CLIENT_SECRET=SEU_CLIENT_SECRET_PLUGGY

# Callback do backend (produção deve ser HTTPS)
AISP_REDIRECT_URI=http://localhost:3333/api/banks/callback

# Opcional (se usar webhook/eventos)
AISP_WEBHOOK_SECRET=

# Chave para criptografia de tokens em repouso (mínimo 32 chars)
TOKEN_ENCRYPTION_KEY=troque-por-uma-chave-forte-com-32-ou-mais-caracteres

# Janela padrão de sincronização
SYNC_DEFAULT_DAYS=90
